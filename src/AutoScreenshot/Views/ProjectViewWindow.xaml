<Window x:Class="AutoScreenshot.Views.ProjectViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoScreenshot - プロジェクトビュー" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        MinHeight="480" MinWidth="720">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左ペイン: プロジェクト一覧 -->
        <DockPanel Grid.Column="0" Margin="6">
            <TextBlock DockPanel.Dock="Top" Text="プロジェクト一覧" FontWeight="Bold" Margin="0,0,0,4"/>
            <Button DockPanel.Dock="Bottom" Content="プロジェクトフォルダを開く"
                    Margin="0,4,0,0" Click="BtnOpenFolder_Click"/>
            <ListBox x:Name="LstProjects" DisplayMemberPath="Title"
                     SelectionChanged="LstProjects_SelectionChanged"/>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

        <!-- 右ペイン: ステップ詳細 -->
        <Grid Grid.Column="2" Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- プロジェクトタイトル -->
            <TextBlock x:Name="TxtProjectTitle" Grid.Row="0"
                       Text="（プロジェクトを選択してください）"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,6"/>

            <!-- ステップ一覧（サムネイルグリッド） -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="LstSteps" SelectionChanged="LstSteps_SelectionChanged">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Width="100" Margin="4"
                                        ToolTip="{Binding EffectiveDescription}"
                                        Opacity="{Binding Opacity}">
                                <Border BorderBrush="LightGray" BorderThickness="1">
                                    <Image Width="96" Height="72"
                                           Stretch="UniformToFill"
                                           Source="{Binding ThumbImageSource}"/>
                                </Border>
                                <TextBlock Text="{Binding StepLabel}" FontSize="9"
                                           TextAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>

            <!-- ステップ詳細エリア -->
            <GroupBox Grid.Row="2" Header="ステップ詳細" Margin="0,6,0,0">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TxtStepInfo" Grid.Row="0" Grid.ColumnSpan="2"
                               Margin="0,0,0,4" FontSize="11" Foreground="Gray"/>

                    <TextBox x:Name="TxtDescription" Grid.Row="1" Grid.Column="0"
                             TextWrapping="Wrap" AcceptsReturn="False"
                             Height="50" VerticalScrollBarVisibility="Auto"
                             ToolTip="説明文を手修正できます。空にするとLLM/ルールベースに戻ります。"/>

                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Margin="4,0,0,0">
                        <Button Content="確定" Width="50" Margin="0,0,0,2" Click="BtnConfirmDesc_Click"/>
                        <Button Content="削除" Width="50" Margin="0,0,0,2" Click="BtnDeleteStep_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="◀ 前へ" Width="60" Margin="0,0,4,0" Click="BtnPrev_Click"/>
                        <Button Content="次へ ▶" Width="60" Click="BtnNext_Click"/>
                        <TextBlock x:Name="TxtStepNav" VerticalAlignment="Center" Margin="8,0,0,0"
                                   FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- エクスポートセクション -->
            <GroupBox Grid.Row="3" Header="エクスポート" Margin="0,6,0,0">
                <StackPanel Orientation="Horizontal" Margin="6">
                    <Button Content="画像" Width="60" Margin="0,0,4,0" Click="BtnExportImages_Click"/>
                    <Button Content="手順書 (Markdown)" Width="120" Margin="0,0,4,0" Click="BtnExportMarkdown_Click"/>
                    <Button Content="手順書 (Word)" Width="100" Margin="0,0,4,0" Click="BtnExportDocx_Click"/>
                    <Button Content="動画" Width="60" Margin="0,0,4,0" Click="BtnExportVideo_Click"/>
                    <Button Content="ZIP" Width="60" Click="BtnExportZip_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- ステータスバー -->
            <TextBlock x:Name="TxtStatus" Grid.Row="4"
                       Margin="0,4,0,0" FontSize="10" Foreground="Gray"/>
        </Grid>
    </Grid>
</Window>
