<Window x:Class="AutoScreenshot.Views.ProjectViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoScreenshot - プロジェクトビュー" Height="660" Width="1040"
        WindowStartupLocation="CenterScreen"
        MinHeight="520" MinWidth="820">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左ペイン: プロジェクト一覧 -->
        <DockPanel Grid.Column="0" Margin="6">
            <TextBlock DockPanel.Dock="Top" Text="プロジェクト一覧" FontWeight="Bold" Margin="0,0,0,4"/>

            <!-- 検索ボックス -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSearch" Grid.Column="0"
                         ToolTip="タイトル・説明文・タグで検索"
                         TextChanged="TxtSearch_TextChanged"/>
                <Button x:Name="BtnSearchClear" Grid.Column="1" Content="×" Width="22"
                        Margin="2,0,0,0" Click="BtnSearchClear_Click" FontSize="11"/>
            </Grid>

            <!-- タグフィルタ -->
            <ScrollViewer DockPanel.Dock="Top" HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto" MaxHeight="58" Margin="0,0,0,4">
                <WrapPanel x:Name="TagPanel" Orientation="Horizontal"/>
            </ScrollViewer>

            <!-- 下部ボタン -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                <Button Content="プロジェクトフォルダを開く" Margin="0,0,0,2"
                        Click="BtnOpenFolder_Click"/>
                <Button x:Name="BtnMergeProjects" Content="結合..." IsEnabled="False"
                        Click="BtnMergeProjects_Click"/>
            </StackPanel>

            <!-- プロジェクト一覧（複数選択可） -->
            <ListBox x:Name="LstProjects" SelectionMode="Extended"
                     SelectionChanged="LstProjects_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="{Binding Title}" FontSize="12"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CreatedAtDisplay}" FontSize="9" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

        <!-- 右ペイン -->
        <Grid Grid.Column="2" Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- タイトル行 + エクスポートボタン -->
                <RowDefinition Height="*"/>      <!-- ステップ一覧 + ステップ詳細 -->
                <RowDefinition Height="Auto"/>   <!-- ステータスバー -->
            </Grid.RowDefinitions>

            <!-- タイトル行 -->
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtProjectTitle" Grid.Column="0"
                           Text="（プロジェクトを選択してください）"
                           FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Button x:Name="BtnExportMenu" Grid.Column="1"
                        Content="▼ エクスポート" Padding="10,4" IsEnabled="False"
                        Click="BtnExportMenu_Click">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="手順書を出力">
                                <MenuItem Header="Markdown (.md)"  Click="BtnExportMarkdown_Click"/>
                                <MenuItem Header="HTML (.html)"    Click="BtnExportHtml_Click"/>
                                <MenuItem Header="Word (.docx)"    Click="BtnExportDocx_Click"/>
                            </MenuItem>
                            <MenuItem Header="動画を生成"          Click="BtnExportVideo_Click"/>
                            <MenuItem Header="画像を書き出す"      Click="BtnExportImages_Click"/>
                            <Separator/>
                            <MenuItem Header="ZIP で保存..."       Click="BtnExportZip_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>

            <!-- メインエリア: ステップ一覧（左）+ ステップ詳細（右） -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="180"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ステップ一覧（縦型） -->
                <DockPanel Grid.Column="0">
                    <!-- ナビゲーション・追加・削除済みトグル（下部固定） -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="◀ 前へ" Width="60" Margin="0,0,4,0" Click="BtnPrev_Click"/>
                            <Button Content="次へ ▶" Width="60" Click="BtnNext_Click"/>
                            <TextBlock x:Name="TxtStepNav" VerticalAlignment="Center" Margin="8,0,0,0"
                                       FontSize="11" Foreground="Gray"/>
                        </StackPanel>
                        <Button Content="＋ ステップを追加" Margin="0,4,0,4"
                                HorizontalAlignment="Stretch" Click="BtnAddStep_Click"/>
                        <CheckBox x:Name="ChkShowDeleted" Content="削除済みを表示"
                                  Checked="ChkShowDeleted_Changed" Unchecked="ChkShowDeleted_Changed"/>
                    </StackPanel>

                    <!-- ステップ一覧本体 -->
                    <ListBox x:Name="LstSteps" SelectionChanged="LstSteps_SelectionChanged"
                             AllowDrop="True"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             PreviewMouseLeftButtonDown="LstSteps_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="LstSteps_PreviewMouseMove"
                             Drop="LstSteps_Drop">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2" Opacity="{Binding Opacity}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="☰"
                                               VerticalAlignment="Center" Margin="0,0,5,0"
                                               Foreground="Gray" FontSize="13"
                                               ToolTip="ドラッグして並び替え"/>
                                    <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1"
                                            Margin="0,0,6,0">
                                        <Image Width="64" Height="48" Stretch="UniformToFill"
                                               Source="{Binding ThumbImageSource}"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StepLabel}"
                                                   FontSize="10" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding EffectiveDescription}"
                                                   FontSize="10" Foreground="Gray"
                                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                   Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

                <!-- ステップ詳細（before → after + アノテーション → ステップ情報） -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- 操作前画像（折りたたみ、最大 120px） -->
                        <RowDefinition Height="230"/>   <!-- アノテーション Canvas -->
                        <RowDefinition Height="Auto"/>  <!-- アノテーションツール（折りたたみ） -->
                        <RowDefinition Height="*"/>     <!-- ステップ詳細（残領域） -->
                    </Grid.RowDefinitions>

                    <!-- 操作前画像（証跡・読み取り専用） -->
                    <Border x:Name="PnlBeforeImage" Grid.Row="0" Background="#EEEEEE"
                            Visibility="Collapsed" MaxHeight="120" Margin="0,0,0,2">
                        <StackPanel>
                            <TextBlock Text="操作前（証跡）" FontSize="10" Foreground="Gray"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            <Image x:Name="ImgBefore" Stretch="Uniform" MaxHeight="96"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </StackPanel>
                    </Border>

                    <!-- 操作後画像（アノテーション Canvas） -->
                    <Border Grid.Row="1" Background="#D8D8D8">
                        <Grid x:Name="AnnGrid">
                            <Image x:Name="ImgAnnotation" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Canvas x:Name="AnnCanvas" Background="Transparent" Cursor="Cross"
                                    SizeChanged="AnnCanvas_SizeChanged"
                                    MouseLeftButtonDown="AnnCanvas_MouseLeftButtonDown"
                                    MouseMove="AnnCanvas_MouseMove"
                                    MouseLeftButtonUp="AnnCanvas_MouseLeftButtonUp"/>
                        </Grid>
                    </Border>

                    <!-- アノテーションツール（折りたたみ） -->
                    <Expander x:Name="ExpAnnotation" Grid.Row="2"
                              Header="アノテーション" IsExpanded="False" Margin="0,2,0,0">
                        <StackPanel Margin="6,4,6,6">
                            <!-- ツール + 色（1行） -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="ツール:" VerticalAlignment="Center"
                                           Margin="0,0,4,0" FontSize="11"/>
                                <Button x:Name="BtnToolNumber"  Content="番号"    Width="44" Margin="0,0,2,0"
                                        Click="BtnTool_Click" Tag="Number" FontWeight="Bold" BorderThickness="2"/>
                                <Button x:Name="BtnToolArrow"   Content="矢印"    Width="44" Margin="0,0,2,0"
                                        Click="BtnTool_Click" Tag="Arrow"/>
                                <Button x:Name="BtnToolRect"    Content="矩形"    Width="44" Margin="0,0,2,0"
                                        Click="BtnTool_Click" Tag="Rect"/>
                                <Button x:Name="BtnToolCallout" Content="吹き出し" Width="56" Margin="0,0,10,0"
                                        Click="BtnTool_Click" Tag="Callout"/>
                                <Border Width="1" Background="LightGray" Margin="0,2,10,2"/>
                                <TextBlock Text="色:" VerticalAlignment="Center"
                                           Margin="0,0,4,0" FontSize="11"/>
                                <Button x:Name="BtnColorRed"    Width="22" Height="22" Margin="0,0,2,0"
                                        Background="#FF0000" BorderBrush="Black" BorderThickness="3"
                                        Click="BtnColor_Click" Tag="#FF0000" ToolTip="赤"/>
                                <Button x:Name="BtnColorBlue"   Width="22" Height="22" Margin="0,0,2,0"
                                        Background="#0078D4" BorderBrush="Gray" BorderThickness="1"
                                        Click="BtnColor_Click" Tag="#0078D4" ToolTip="青"/>
                                <Button x:Name="BtnColorYellow" Width="22" Height="22" Margin="0,0,2,0"
                                        Background="#FFC000" BorderBrush="Gray" BorderThickness="1"
                                        Click="BtnColor_Click" Tag="#FFC000" ToolTip="黄"/>
                                <Button x:Name="BtnColorGreen"  Width="22" Height="22"
                                        Background="#107C10" BorderBrush="Gray" BorderThickness="1"
                                        Click="BtnColor_Click" Tag="#107C10" ToolTip="緑"/>
                            </StackPanel>
                            <!-- クリア・保存 -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="クリア"       Width="60" Margin="0,0,6,0" Click="BtnAnnClear_Click"/>
                                <Button Content="確定（保存）" Width="84"                   Click="BtnAnnSave_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- ステップ詳細（情報・説明文・操作ボタン） -->
                    <GroupBox Grid.Row="3" Header="ステップ詳細" Margin="0,4,0,0">
                        <Grid Margin="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="TxtStepInfo" Grid.Row="0" Grid.ColumnSpan="2"
                                       Margin="0,0,0,4" FontSize="11" Foreground="Gray"/>

                            <TextBox x:Name="TxtDescription" Grid.Row="1" Grid.Column="0"
                                     TextWrapping="Wrap" AcceptsReturn="False"
                                     MinHeight="48" VerticalScrollBarVisibility="Auto"
                                     VerticalAlignment="Stretch"
                                     ToolTip="説明文を手修正できます。空にするとLLM/ルールベースに戻ります。"/>

                            <StackPanel Grid.Row="1" Grid.Column="1"
                                        Orientation="Vertical" Margin="4,0,0,0"
                                        VerticalAlignment="Top">
                                <Button Content="確定"       Width="64" Margin="0,0,0,2" Click="BtnConfirmDesc_Click"/>
                                <Button Content="削除"       Width="64" Margin="0,0,0,2" Click="BtnDeleteStep_Click"/>
                                <Button Content="ここで分割" Width="64"                   Click="BtnSplitHere_Click"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </Grid>

            <!-- ステータスバー -->
            <Grid Grid.Row="2" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Grid.Column="0"
                           FontSize="10" Foreground="Gray" VerticalAlignment="Center"/>
                <ProgressBar x:Name="PbStatus" Grid.Column="1"
                             Width="100" Height="6" Margin="8,0,0,0"
                             IsIndeterminate="True" Visibility="Collapsed"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
