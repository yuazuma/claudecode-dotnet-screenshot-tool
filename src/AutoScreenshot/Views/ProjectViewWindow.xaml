<Window x:Class="AutoScreenshot.Views.ProjectViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoScreenshot - プロジェクトビュー" Height="640" Width="1040"
        WindowStartupLocation="CenterScreen"
        MinHeight="500" MinWidth="820">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左ペイン: プロジェクト一覧 -->
        <DockPanel Grid.Column="0" Margin="6">
            <TextBlock DockPanel.Dock="Top" Text="プロジェクト一覧" FontWeight="Bold" Margin="0,0,0,4"/>

            <!-- 検索ボックス -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSearch" Grid.Column="0"
                         ToolTip="タイトル・説明文・タグで検索"
                         TextChanged="TxtSearch_TextChanged"/>
                <Button x:Name="BtnSearchClear" Grid.Column="1" Content="×" Width="22"
                        Margin="2,0,0,0" Click="BtnSearchClear_Click" FontSize="11"/>
            </Grid>

            <!-- タグフィルタ -->
            <ScrollViewer DockPanel.Dock="Top" HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto" MaxHeight="58" Margin="0,0,0,4">
                <WrapPanel x:Name="TagPanel" Orientation="Horizontal"/>
            </ScrollViewer>

            <!-- 下部ボタン -->
            <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                <Button Content="プロジェクトフォルダを開く" Margin="0,0,0,2"
                        Click="BtnOpenFolder_Click"/>
                <Button x:Name="BtnMergeProjects" Content="結合..." IsEnabled="False"
                        Click="BtnMergeProjects_Click"/>
            </StackPanel>

            <!-- プロジェクト一覧（複数選択可） -->
            <ListBox x:Name="LstProjects" SelectionMode="Extended"
                     SelectionChanged="LstProjects_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,2">
                            <TextBlock Text="{Binding Title}" FontSize="12"
                                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CreatedAtDisplay}" FontSize="9" Foreground="Gray"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

        <!-- 右ペイン: ステップ詳細 -->
        <Grid Grid.Column="2" Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- プロジェクトタイトル -->
            <TextBlock x:Name="TxtProjectTitle" Grid.Row="0"
                       Text="（プロジェクトを選択してください）"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,6"/>

            <!-- Row 1: サムネイルグリッド + アノテーションパネル -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="180"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="310" MinWidth="220"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="LstSteps" SelectionChanged="LstSteps_SelectionChanged"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="LstSteps_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="LstSteps_PreviewMouseMove"
                             Drop="LstSteps_Drop">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="100" Margin="4"
                                            ToolTip="{Binding EffectiveDescription}"
                                            Opacity="{Binding Opacity}">
                                    <Border BorderBrush="LightGray" BorderThickness="1">
                                        <Image Width="96" Height="72"
                                               Stretch="UniformToFill"
                                               Source="{Binding ThumbImageSource}"/>
                                    </Border>
                                    <TextBlock Text="{Binding StepLabel}" FontSize="9"
                                               TextAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"/>

                <!-- アノテーションパネル -->
                <GroupBox Grid.Column="2" Header="アノテーション">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,4,4,2">
                            <TextBlock Text="ツール:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                            <Button x:Name="BtnToolNumber" Content="番号" Width="44" Margin="0,0,2,0"
                                    Click="BtnTool_Click" Tag="Number" FontWeight="Bold" BorderThickness="2"/>
                            <Button x:Name="BtnToolArrow"  Content="矢印" Width="44" Margin="0,0,2,0"
                                    Click="BtnTool_Click" Tag="Arrow"/>
                            <Button x:Name="BtnToolRect"   Content="矩形" Width="44" Margin="0,0,2,0"
                                    Click="BtnTool_Click" Tag="Rect"/>
                            <Button x:Name="BtnToolCallout" Content="吹き出し" Width="56"
                                    Click="BtnTool_Click" Tag="Callout"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4,0,4,4">
                            <TextBlock Text="色:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                            <Button x:Name="BtnColorRed"    Width="22" Height="22" Margin="0,0,2,0"
                                    Background="#FF0000" BorderBrush="Black" BorderThickness="3"
                                    Click="BtnColor_Click" Tag="#FF0000" ToolTip="赤"/>
                            <Button x:Name="BtnColorBlue"   Width="22" Height="22" Margin="0,0,2,0"
                                    Background="#0078D4" BorderBrush="Gray" BorderThickness="1"
                                    Click="BtnColor_Click" Tag="#0078D4" ToolTip="青"/>
                            <Button x:Name="BtnColorYellow" Width="22" Height="22" Margin="0,0,2,0"
                                    Background="#FFC000" BorderBrush="Gray" BorderThickness="1"
                                    Click="BtnColor_Click" Tag="#FFC000" ToolTip="黄"/>
                            <Button x:Name="BtnColorGreen"  Width="22" Height="22"
                                    Background="#107C10" BorderBrush="Gray" BorderThickness="1"
                                    Click="BtnColor_Click" Tag="#107C10" ToolTip="緑"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="4,4,4,4">
                            <Button Content="クリア" Width="60" Margin="0,0,6,0" Click="BtnAnnClear_Click"/>
                            <Button Content="確定（保存）" Width="84" Click="BtnAnnSave_Click"/>
                        </StackPanel>
                        <Border Background="#D8D8D8">
                            <Grid x:Name="AnnGrid">
                                <Image x:Name="ImgAnnotation" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Canvas x:Name="AnnCanvas" Background="Transparent" Cursor="Cross"
                                        SizeChanged="AnnCanvas_SizeChanged"
                                        MouseLeftButtonDown="AnnCanvas_MouseLeftButtonDown"
                                        MouseMove="AnnCanvas_MouseMove"
                                        MouseLeftButtonUp="AnnCanvas_MouseLeftButtonUp"/>
                            </Grid>
                        </Border>
                    </DockPanel>
                </GroupBox>
            </Grid>

            <!-- ステップ詳細エリア -->
            <GroupBox Grid.Row="2" Header="ステップ詳細" Margin="0,6,0,0">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TxtStepInfo" Grid.Row="0" Grid.ColumnSpan="2"
                               Margin="0,0,0,4" FontSize="11" Foreground="Gray"/>

                    <TextBox x:Name="TxtDescription" Grid.Row="1" Grid.Column="0"
                             TextWrapping="Wrap" AcceptsReturn="False"
                             Height="50" VerticalScrollBarVisibility="Auto"
                             ToolTip="説明文を手修正できます。空にするとLLM/ルールベースに戻ります。"/>

                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Margin="4,0,0,0">
                        <Button Content="確定" Width="64" Margin="0,0,0,2" Click="BtnConfirmDesc_Click"/>
                        <Button Content="削除" Width="64" Margin="0,0,0,2" Click="BtnDeleteStep_Click"/>
                        <Button Content="ここで分割" Width="64" Margin="0,0,0,0" Click="BtnSplitHere_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="◀ 前へ" Width="60" Margin="0,0,4,0" Click="BtnPrev_Click"/>
                        <Button Content="次へ ▶" Width="60" Click="BtnNext_Click"/>
                        <TextBlock x:Name="TxtStepNav" VerticalAlignment="Center" Margin="8,0,0,0"
                                   FontSize="11" Foreground="Gray"/>
                        <Button Content="＋ステップを追加" Width="110" Margin="8,0,0,0"
                                Click="BtnAddStep_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- エクスポートセクション -->
            <GroupBox Grid.Row="3" Header="エクスポート" Margin="0,6,0,0">
                <StackPanel Orientation="Horizontal" Margin="6" FlowDirection="LeftToRight">
                    <Button Content="画像" Width="60" Margin="0,0,4,0" Click="BtnExportImages_Click"/>
                    <Button Content="手順書 (MD)" Width="100" Margin="0,0,4,0" Click="BtnExportMarkdown_Click"/>
                    <Button Content="手順書 (HTML)" Width="110" Margin="0,0,4,0" Click="BtnExportHtml_Click"/>
                    <Button Content="手順書 (Word)" Width="100" Margin="0,0,4,0" Click="BtnExportDocx_Click"/>
                    <Button Content="動画" Width="60" Margin="0,0,4,0" Click="BtnExportVideo_Click"/>
                    <Button Content="ZIP" Width="60" Click="BtnExportZip_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- ステータスバー -->
            <TextBlock x:Name="TxtStatus" Grid.Row="4"
                       Margin="0,4,0,0" FontSize="10" Foreground="Gray"/>
        </Grid>
    </Grid>
</Window>
