<Window x:Class="AutoScreenshot.Views.ExportProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="エクスポート — AutoScreenshot"
        Width="400" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Topmost="False"
        Closing="Window_Closing">
    <StackPanel Margin="16">
        <TextBlock x:Name="TxtOperation"
                   Text="処理中..."
                   FontSize="13" FontWeight="SemiBold"
                   TextTrimming="CharacterEllipsis"
                   Margin="0,0,0,8"/>

        <ProgressBar x:Name="PbProgress"
                     Height="12"
                     Minimum="0" Maximum="100"
                     IsIndeterminate="True"
                     Margin="0,0,0,6"/>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TxtOutputPath"
                       Grid.Column="0"
                       FontSize="10" Foreground="Gray"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"/>
            <TextBlock x:Name="TxtCounter"
                       Grid.Column="1"
                       FontSize="10" Foreground="Gray"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"/>
        </Grid>

        <Button x:Name="BtnCancel"
                Content="キャンセル"
                Width="90" HorizontalAlignment="Right"
                Click="BtnCancel_Click"/>
    </StackPanel>
</Window>
