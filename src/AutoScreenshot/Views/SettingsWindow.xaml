<Window x:Class="AutoScreenshot.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoScreenshot - 設定" Height="600" Width="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">

            <!-- 一般 -->
            <TabItem Header="一般">
                <StackPanel Margin="10" VerticalAlignment="Top">
                    <CheckBox x:Name="ChkAutoStart" Content="Windows ログオン時に自動起動する" Margin="0,5"/>
                    <TextBlock Text="ホットキー (一時停止/再開):" Margin="0,10,0,2"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TxtHotkey" Width="160" IsReadOnly="True"
                                 ToolTip="クリックしてからキーを押してください (例: Ctrl+F9)"
                                 PreviewKeyDown="TxtHotkey_PreviewKeyDown"
                                 GotFocus="TxtHotkey_GotFocus"
                                 LostFocus="TxtHotkey_LostFocus"/>
                        <Button Content="クリア" Width="55" Margin="5,0,0,0" Click="BtnClearHotkey_Click"/>
                    </StackPanel>
                    <TextBlock Text="例: Ctrl+F9 / Alt+F12 / Ctrl+Shift+F10" Margin="0,2,0,0"
                               FontSize="10" Foreground="Gray"/>
                </StackPanel>
            </TabItem>

            <!-- 撮影トリガー -->
            <TabItem Header="撮影トリガー">
                <ScrollViewer>
                    <StackPanel Margin="10" VerticalAlignment="Top">
                        <TextBlock Text="マウスイベント" FontWeight="Bold" Margin="0,5,0,3"/>
                        <CheckBox x:Name="ChkMouseLeft"   Content="左クリック" Margin="10,2"/>
                        <CheckBox x:Name="ChkMouseRight"  Content="右クリック" Margin="10,2"/>
                        <CheckBox x:Name="ChkMouseMiddle" Content="中クリック" Margin="10,2"/>
                        <CheckBox x:Name="ChkMouseDrag"   Content="ドラッグ完了" Margin="10,2"/>
                        <CheckBox x:Name="ChkMouseWheel"  Content="ホイール操作" Margin="10,2"/>
                        <StackPanel Orientation="Horizontal" Margin="20,3">
                            <TextBlock Text="ドラッグ判定時間:" VerticalAlignment="Center" Width="120"/>
                            <Slider x:Name="SldrDragThreshold" Minimum="50" Maximum="1000" Width="130"
                                    TickFrequency="50" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrDragThreshold, Path=Value, StringFormat='{}{0}ms'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="20,3">
                            <TextBlock Text="ホイールアイドル:" VerticalAlignment="Center" Width="120"/>
                            <Slider x:Name="SldrWheelIdle" Minimum="100" Maximum="2000" Width="130"
                                    TickFrequency="100" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrWheelIdle, Path=Value, StringFormat='{}{0}ms'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>

                        <TextBlock Text="キーボード" FontWeight="Bold" Margin="0,10,0,3"/>
                        <CheckBox x:Name="ChkKeyboard" Content="キー入力後まとめ撮影" Margin="10,2"/>
                        <StackPanel Orientation="Horizontal" Margin="10,5">
                            <TextBlock Text="アイドル待機時間:" VerticalAlignment="Center" Width="130"/>
                            <Slider x:Name="SldrKeyboardIdle" Minimum="0.5" Maximum="10" Width="150"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrKeyboardIdle, Path=Value, StringFormat='{}{0:0.0}秒'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>

                        <TextBlock Text="画面変更検知" FontWeight="Bold" Margin="0,10,0,3"/>
                        <CheckBox x:Name="ChkActiveWindow" Content="アクティブウィンドウ切替" Margin="10,2"/>
                        <CheckBox x:Name="ChkScreenDiff"   Content="画面差分検知" Margin="10,2"/>
                        <StackPanel Orientation="Horizontal" Margin="10,5">
                            <TextBlock Text="差分チェック間隔:" VerticalAlignment="Center" Width="130"/>
                            <Slider x:Name="SldrDiffInterval" Minimum="1" Maximum="30" Width="150"
                                    TickFrequency="1" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrDiffInterval, Path=Value, StringFormat='{}{0}秒'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,5">
                            <TextBlock Text="差分検知閾値:" VerticalAlignment="Center" Width="130"/>
                            <Slider x:Name="SldrDiffThreshold" Minimum="5" Maximum="80" Width="150"
                                    TickFrequency="5" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrDiffThreshold, Path=Value, StringFormat='{}{0}%'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>

                        <TextBlock Text="クールダウン (秒)" FontWeight="Bold" Margin="0,10,0,3"/>
                        <TextBlock Text="同じトリガーが短時間に連続発火しないよう間引く最小間隔です。"
                                   FontSize="10" Foreground="Gray" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="10,3">
                            <TextBlock Text="クリック:" VerticalAlignment="Center" Width="130"/>
                            <Slider x:Name="SldrCooldownClick" Minimum="0.5" Maximum="10" Width="150"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrCooldownClick, Path=Value, StringFormat='{}{0:0.0}秒'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,3">
                            <TextBlock Text="ドラッグ:" VerticalAlignment="Center" Width="130"/>
                            <Slider x:Name="SldrCooldownDrag" Minimum="0.5" Maximum="10" Width="150"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrCooldownDrag, Path=Value, StringFormat='{}{0:0.0}秒'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,3">
                            <TextBlock Text="ホイール:" VerticalAlignment="Center" Width="130"/>
                            <Slider x:Name="SldrCooldownWheel" Minimum="0.5" Maximum="10" Width="150"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrCooldownWheel, Path=Value, StringFormat='{}{0:0.0}秒'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,3">
                            <TextBlock Text="キーボード:" VerticalAlignment="Center" Width="130"/>
                            <Slider x:Name="SldrCooldownKeyboard" Minimum="0.5" Maximum="10" Width="150"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrCooldownKeyboard, Path=Value, StringFormat='{}{0:0.0}秒'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,3">
                            <TextBlock Text="ウィンドウ切替:" VerticalAlignment="Center" Width="130"/>
                            <Slider x:Name="SldrCooldownWindow" Minimum="0.5" Maximum="10" Width="150"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrCooldownWindow, Path=Value, StringFormat='{}{0:0.0}秒'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="10,3">
                            <TextBlock Text="画面差分:" VerticalAlignment="Center" Width="130"/>
                            <Slider x:Name="SldrCooldownDiff" Minimum="0.5" Maximum="10" Width="150"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrCooldownDiff, Path=Value, StringFormat='{}{0:0.0}秒'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 保存 -->
            <TabItem Header="保存">
                <StackPanel Margin="10" VerticalAlignment="Top">
                    <TextBlock Text="保存先フォルダ:" Margin="0,5,0,2"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="参照..." Width="60" Margin="5,0,0,0" Click="BtnBrowse_Click"/>
                        <TextBox x:Name="TxtSaveFolder" IsReadOnly="False"/>
                    </DockPanel>
                    <TextBlock Text="ファイル形式:" Margin="0,10,0,2"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="RdoPng"  Content="PNG"  Margin="0,0,10,0" GroupName="Format" Checked="RdoFormat_Checked"/>
                        <RadioButton x:Name="RdoJpeg" Content="JPEG" Margin="0,0,10,0" GroupName="Format" Checked="RdoFormat_Checked"/>
                        <RadioButton x:Name="RdoWebP" Content="WebP"                   GroupName="Format" Checked="RdoFormat_Checked"/>
                    </StackPanel>
                    <StackPanel x:Name="PnlJpegQuality" Orientation="Horizontal" Margin="0,5" Visibility="Collapsed">
                        <TextBlock Text="画質 (JPEG/WebP):" VerticalAlignment="Center" Width="130"/>
                        <Slider x:Name="SldrJpegQuality" Minimum="60" Maximum="100" Width="130"
                                TickFrequency="5" IsSnapToTickEnabled="True"/>
                        <TextBlock Text="{Binding ElementName=SldrJpegQuality, Path=Value, StringFormat='{}{0}'}"
                                   VerticalAlignment="Center" Margin="5,0"/>
                    </StackPanel>
                    <TextBlock Text="フォルダ命名規則:" Margin="0,10,0,2"/>
                    <ComboBox x:Name="CmbNaming" Width="300" HorizontalAlignment="Left">
                        <ComboBoxItem Content="日付フォルダ + タイムスタンプ名"/>
                        <ComboBoxItem Content="日付 + 時間帯階層"/>
                        <ComboBoxItem Content="セッション単位"/>
                        <ComboBoxItem Content="フラット"/>
                    </ComboBox>
                </StackPanel>
            </TabItem>

            <!-- プライバシー -->
            <TabItem Header="プライバシー">
                <StackPanel Margin="10" VerticalAlignment="Top">
                    <CheckBox x:Name="ChkMaskPassword" Content="パスワード欄を自動マスキング" Margin="0,5"/>
                    <TextBlock Text="除外アプリ (プロセス名またはウィンドウタイトル、ワイルドカード対応):"
                               Margin="0,10,0,2"/>
                    <TextBox x:Name="TxtExcludeApps" AcceptsReturn="True" Height="120"
                             VerticalScrollBarVisibility="Auto"
                             ToolTip="1行に1つ入力。例: KeePass*" FontFamily="Consolas"/>
                </StackPanel>
            </TabItem>

            <!-- メタデータ -->
            <TabItem Header="メタデータ">
                <StackPanel Margin="10" VerticalAlignment="Top">
                    <TextBlock Text="サイドカーログ:" FontWeight="Bold" Margin="0,5,0,5"/>
                    <CheckBox x:Name="ChkSidecarLog" Content="撮影ごとにテキストログ (.log) を生成する" Margin="0,3"/>
                    <TextBlock Text="画像への情報付与:" FontWeight="Bold" Margin="0,15,0,5"/>
                    <CheckBox x:Name="ChkBurnTimestamp" Content="撮影日時を画像に焼き込む" Margin="0,3"/>
                    <CheckBox x:Name="ChkImageOverlay" Content="カーソル位置マーカーを画像に描画する" Margin="0,3"/>
                    <TextBlock Text="構造化ログ:" FontWeight="Bold" Margin="0,15,0,5"/>
                    <CheckBox x:Name="ChkStructuredOutput" Content="JSONL/CSV 構造化ログを出力する" Margin="0,3"
                              Checked="ChkStructuredOutput_Changed" Unchecked="ChkStructuredOutput_Changed"/>
                    <StackPanel x:Name="PnlStructFmt" Orientation="Horizontal" Margin="20,5" IsEnabled="False">
                        <RadioButton x:Name="RdoJsonLines" Content="JSON Lines (.jsonl)" GroupName="StructFmt" Margin="0,0,15,0"/>
                        <RadioButton x:Name="RdoCsv"       Content="CSV (.csv)"           GroupName="StructFmt"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- 通知 -->
            <TabItem Header="通知">
                <StackPanel Margin="10" VerticalAlignment="Top">
                    <TextBlock Text="撮影時のフィードバック:" FontWeight="Bold" Margin="0,5,0,5"/>
                    <CheckBox x:Name="ChkFlash"   Content="トレイアイコン点滅" Margin="0,3"/>
                    <CheckBox x:Name="ChkToast"   Content="トースト通知" Margin="0,3"/>
                    <CheckBox x:Name="ChkCounter" Content="撮影枚数をツールチップに表示" Margin="0,3"/>
                </StackPanel>
            </TabItem>

            <!-- 手順書生成 -->
            <TabItem Header="手順書生成">
                <ScrollViewer>
                    <StackPanel Margin="10" VerticalAlignment="Top">
                        <CheckBox x:Name="ChkManualEnabled" Content="操作手順書の自動生成を有効にする" Margin="0,5"/>

                        <TextBlock Text="出力先フォルダ:" Margin="0,10,0,2"/>
                        <TextBlock Text="空欄の場合: {スクリーンショット保存フォルダ}/manuals/"
                                   FontSize="10" Foreground="Gray" Margin="0,0,0,2"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="参照..." Width="60" Margin="5,0,0,0"
                                    Click="BtnBrowseManualFolder_Click"/>
                            <TextBox x:Name="TxtManualOutputFolder"/>
                        </DockPanel>

                        <TextBlock Text="スクリーンショット添付:" FontWeight="Bold" Margin="0,12,0,3"/>
                        <ComboBox x:Name="CmbScreenshotMode" Width="220" HorizontalAlignment="Left">
                            <ComboBoxItem Content="全ステップに添付 (All)"/>
                            <ComboBoxItem Content="ウィンドウ切替時のみ (WindowChange)"/>
                            <ComboBoxItem Content="添付しない (None)"/>
                        </ComboBox>

                        <TextBlock Text="キーボード入力の記録方式:" FontWeight="Bold" Margin="0,12,0,3"/>
                        <ComboBox x:Name="CmbKeyboardMode" Width="220" HorizontalAlignment="Left">
                            <ComboBoxItem Content="実文字列のみ (RealText)"/>
                            <ComboBoxItem Content="キーコードのみ (KeyCode)"/>
                            <ComboBoxItem Content="両方 (Both)"/>
                        </ComboBox>

                        <TextBlock Text="章の時間区切り:" FontWeight="Bold" Margin="0,12,0,3"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="SldrChapterTimeGap" Minimum="1" Maximum="30" Width="150"
                                    TickFrequency="1" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrChapterTimeGap, Path=Value, StringFormat='{}{0}分'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>
                        <TextBlock Text="同一ウィンドウ内でこの時間以上経過すると小見出しを挿入します。"
                                   FontSize="10" Foreground="Gray" Margin="0,2,0,0"/>

                        <CheckBox x:Name="ChkManualShowTitleDialog"
                                  Content="セッション開始時にタイトル入力ダイアログを表示する"
                                  Margin="0,12,0,0"/>

                        <TextBlock Text="出力形式:" FontWeight="Bold" Margin="0,12,0,3"/>
                        <CheckBox x:Name="ChkOutputMarkdown" Content="Markdown (.md)" Margin="0,3"/>
                        <CheckBox x:Name="ChkOutputDocx"     Content="Word (.docx)" Margin="0,3"/>

                        <TextBlock Text="テンプレートファイル (任意 / O-07):" FontWeight="Bold" Margin="0,12,0,3"/>
                        <TextBlock Text="Markdown テンプレート (.md):" Margin="0,4,0,2"/>
                        <TextBlock FontSize="10" Foreground="Gray" Margin="0,0,0,2"
                                   Text="{}{content} プレースホルダーを含む場合はそこに挿入、含まない場合はテンプレートの後ろに追記します。"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="参照..." Width="60" Margin="5,0,0,0"
                                    Click="BtnBrowseMarkdownTemplate_Click"/>
                            <TextBox x:Name="TxtTemplateMarkdownPath"/>
                        </DockPanel>

                        <TextBlock Text="Word テンプレート (.dotx):" Margin="0,8,0,2"/>
                        <TextBlock FontSize="10" Foreground="Gray" Margin="0,0,0,2"
                                   Text="テンプレートのスタイルを使用して docx を生成します。"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="参照..." Width="60" Margin="5,0,0,0"
                                    Click="BtnBrowseDotxTemplate_Click"/>
                            <TextBox x:Name="TxtTemplateDotxPath"/>
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- LLM連携 (L-01) -->
            <TabItem Header="LLM連携">
                <ScrollViewer>
                    <StackPanel Margin="10" VerticalAlignment="Top">
                        <CheckBox x:Name="ChkLlmEnabled" Content="LLM 連携を有効にする" Margin="0,5"/>
                        <TextBlock FontSize="10" Foreground="Gray" Margin="0,2,0,8"
                                   Text="エンドポイント URL と API キーが両方設定されている場合のみ有効になります。"/>

                        <TextBlock Text="Microsoft Azure AI Foundry エンドポイント URL:" Margin="0,5,0,2"/>
                        <TextBlock FontSize="10" Foreground="Gray" Margin="0,0,0,2"
                                   Text="例: https://&lt;resource&gt;.services.ai.azure.com/models"/>
                        <PasswordBox x:Name="PwdLlmEndpoint"/>

                        <TextBlock Text="Azure AI Foundry API キー:" Margin="0,10,0,2"/>
                        <PasswordBox x:Name="PwdLlmApiKey"/>

                        <TextBlock Text="デプロイメント名 (モデル識別子):" Margin="0,10,0,2"/>
                        <TextBlock FontSize="10" Foreground="Gray" Margin="0,0,0,2"
                                   Text="Azure AI Foundry プロジェクトのデプロイ名を入力してください。"/>
                        <TextBox x:Name="TxtLlmDeploymentName" Width="280" HorizontalAlignment="Left"/>

                        <TextBlock FontSize="10" Foreground="Gray" Margin="0,16,0,0" TextWrapping="Wrap"
                                   Text="※ Azure AI Foundry 上にデプロイされた Claude モデルを呼び出します。スクリーンショット画像は送信されません（テキスト情報のみ）。"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 動画生成 -->
            <TabItem Header="動画生成">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10" VerticalAlignment="Top">

                        <!-- 出力形式 -->
                        <TextBlock Text="出力形式" FontWeight="Bold" Margin="0,0,0,4"/>
                        <CheckBox x:Name="ChkVideoApng" Content="APNG を出力する" Margin="0,2"/>
                        <CheckBox x:Name="ChkVideoMp4"  Content="MP4 を出力する"  Margin="0,2"/>

                        <!-- 出力フォルダ -->
                        <TextBlock Text="動画出力フォルダ:" Margin="0,10,0,2"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="TxtVideoFolder" Width="320" HorizontalAlignment="Left"/>
                            <Button Content="参照..." Width="55" Margin="5,0,0,0" Click="BtnVideoFolderBrowse_Click"/>
                        </StackPanel>

                        <!-- 構成単位 -->
                        <TextBlock Text="動画の構成単位:" Margin="0,10,0,2"/>
                        <RadioButton x:Name="RdoVideoSession" Content="セッション全体を1本の動画にまとめる" Margin="0,2" GroupName="VideoUnit"/>
                        <RadioButton x:Name="RdoVideoChapter" Content="チャプター（ウィンドウ）ごとに分割する"  Margin="0,2" GroupName="VideoUnit"/>

                        <!-- フレーム表示時間 -->
                        <TextBlock Text="フレーム表示時間:" Margin="0,10,0,2"/>
                        <RadioButton x:Name="RdoFrameFixed"   Content="固定秒数" Margin="0,2" GroupName="FrameTiming"
                                     Checked="RdoFrameTiming_Changed" Unchecked="RdoFrameTiming_Changed"/>
                        <RadioButton x:Name="RdoFrameRealTime" Content="実時間再現" Margin="0,2" GroupName="FrameTiming"
                                     Checked="RdoFrameTiming_Changed" Unchecked="RdoFrameTiming_Changed"/>
                        <StackPanel x:Name="PnlFixedFrame" Orientation="Horizontal" Margin="16,4,0,0">
                            <TextBlock Text="固定秒数:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="TxtFixedFrameSec" Width="50"/>
                            <TextBlock Text="秒" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                        <StackPanel x:Name="PnlRealTimeFrame" Orientation="Horizontal" Margin="16,4,0,0">
                            <TextBlock Text="最小:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="TxtMinFrameSec" Width="40"/>
                            <TextBlock Text="秒  最大:" VerticalAlignment="Center" Margin="4,0,4,0"/>
                            <TextBox x:Name="TxtMaxFrameSec" Width="40"/>
                            <TextBlock Text="秒" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>

                        <!-- 解像度・品質 -->
                        <TextBlock Text="出力解像度:" Margin="0,10,0,2"/>
                        <RadioButton x:Name="RdoResOriginal" Content="原寸（撮影時の解像度）" Margin="0,2" GroupName="VideoRes"/>
                        <RadioButton x:Name="RdoResFhd"      Content="1920×1080 (FHD)"       Margin="0,2" GroupName="VideoRes"/>
                        <RadioButton x:Name="RdoResHd"       Content="1280×720 (HD)"          Margin="0,2" GroupName="VideoRes"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="MP4 映像ビットレート:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="TxtMp4Bitrate" Width="40"/>
                            <TextBlock Text="Mbps" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>

                        <!-- 強調表示 -->
                        <TextBlock Text="強調表示" FontWeight="Bold" Margin="0,10,0,4"/>
                        <CheckBox x:Name="ChkDrawRipple"    Content="クリック位置に波紋アニメーションを描画する" Margin="0,2"/>
                        <CheckBox x:Name="ChkDrawRectangle" Content="操作対象コントロールに矩形枠を描画する"    Margin="0,2"/>

                        <!-- テロップ -->
                        <TextBlock Text="テロップ（字幕）" FontWeight="Bold" Margin="0,10,0,4"/>
                        <CheckBox x:Name="ChkShowTelop"         Content="テロップを表示する"         Margin="0,2"/>
                        <CheckBox x:Name="ChkTelopEventLabel"   Content="  イベント種別ラベル"       Margin="16,2"/>
                        <CheckBox x:Name="ChkTelopInputText"    Content="  入力テキスト"             Margin="16,2"/>
                        <CheckBox x:Name="ChkTelopDescription"  Content="  操作の説明文"             Margin="16,2"/>
                        <CheckBox x:Name="ChkTelopTimestamp"    Content="  タイムスタンプ"           Margin="16,2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="フォントサイズ:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="TxtTelopFontSize" Width="40"/>
                            <TextBlock Text="pt  背景透明度:" VerticalAlignment="Center" Margin="8,0,4,0"/>
                            <TextBox x:Name="TxtTelopBgAlpha" Width="40"/>
                            <TextBlock Text="(0〜255)" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>

                        <!-- TTS -->
                        <TextBlock Text="TTS ナレーション" FontWeight="Bold" Margin="0,10,0,4"/>
                        <CheckBox x:Name="ChkTtsEnabled" Content="TTS ナレーションを有効にする" Margin="0,2"/>
                        <TextBlock Text="音声（ボイス名。空欄=OS既定）:" Margin="0,6,0,2"/>
                        <TextBox x:Name="TxtTtsVoice" Width="200" HorizontalAlignment="Left"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="速度:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="TxtTtsRate" Width="35"/>
                            <TextBlock Text="(-10〜10)  音量:" VerticalAlignment="Center" Margin="4,0,4,0"/>
                            <TextBox x:Name="TxtTtsVolume" Width="35"/>
                            <TextBlock Text="(0〜100)" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>

                        <!-- 生成タイミング -->
                        <TextBlock Text="生成タイミング" FontWeight="Bold" Margin="0,10,0,4"/>
                        <CheckBox x:Name="ChkAutoGenerateVideo"
                                  Content="手順書生成と同時に動画を自動生成する（既定: 手動）"
                                  Margin="0,2"/>

                        <!-- 完了時 -->
                        <TextBlock Text="完了時の動作" FontWeight="Bold" Margin="0,10,0,4"/>
                        <CheckBox x:Name="ChkOpenFolderOnComplete"
                                  Content="動画生成完了後にエクスプローラーで出力フォルダを開く"
                                  Margin="0,2"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- プロジェクト -->
            <TabItem Header="プロジェクト">
                <ScrollViewer>
                    <StackPanel Margin="10" VerticalAlignment="Top">
                        <CheckBox x:Name="ChkProjectEnabled"
                                  Content="プロジェクトファイル機能を有効にする（オフにすると v1.1.0 以前の動作）"
                                  Margin="0,5"/>
                        <Separator Margin="0,8"/>

                        <TextBlock Text="サムネイル設定" FontWeight="Bold" Margin="0,4,0,3"/>
                        <StackPanel Orientation="Horizontal" Margin="10,2">
                            <TextBlock Text="サムネイル最大幅:" VerticalAlignment="Center" Width="130"/>
                            <Slider x:Name="SldrThumbnailWidth" Minimum="80" Maximum="640" Width="130"
                                    TickFrequency="80" IsSnapToTickEnabled="True"/>
                            <TextBlock Text="{Binding ElementName=SldrThumbnailWidth, Path=Value, StringFormat='{}{0}px'}"
                                       VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>

                        <Separator Margin="0,8"/>
                        <TextBlock Text="終了時の自動エクスポート" FontWeight="Bold" Margin="0,4,0,3"/>
                        <CheckBox x:Name="ChkAutoExportMarkdown"
                                  Content="Markdown 手順書を自動エクスポート（既定: オン）"
                                  Margin="10,2"/>
                        <CheckBox x:Name="ChkAutoExportDocx"
                                  Content="Word 手順書を自動エクスポート（既定: オフ）"
                                  Margin="10,2"/>
                        <CheckBox x:Name="ChkAutoExportVideo"
                                  Content="動画（APNG/MP4）を自動エクスポート（既定: オフ）"
                                  Margin="10,2"/>

                        <Separator Margin="0,8"/>
                        <CheckBox x:Name="ChkOpenFolderOnExport"
                                  Content="エクスポート完了時に exports/ フォルダを自動で開く"
                                  Margin="0,5"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ボタン行 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="80" Margin="5,0" Click="BtnOk_Click" IsDefault="True"/>
            <Button Content="キャンセル" Width="80" Margin="5,0" Click="BtnCancel_Click" IsCancel="True"/>
            <Button Content="適用" Width="80" Margin="5,0" Click="BtnApply_Click"/>
        </StackPanel>
    </Grid>
</Window>
